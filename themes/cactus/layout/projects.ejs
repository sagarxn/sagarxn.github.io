<div id="archive">
  <ul class="post-list">
    <% var year = 0 %>
    <% var change = false %>
    <% const projects = site.data.projects || [] %>
    <% const sortedProjects = projects.sort((a, b) => new Date(b.date) - new Date(a.date)) %>
    
    <% sortedProjects.forEach(function(project) { %>
      <% var projectDate = new Date(project.date) %>
      <% var itemYear = projectDate.getFullYear() %>
      <% change = year !== itemYear %>
      <% year = change ? itemYear : year %>
      
      <% if (change) { %>
        <li class="post-year"><h2><%= year %></h2></li>
      <% } %>
      
      <li class="post-item">
        <span class="meta"><%= moment(project.date).format('YYYY-MM') %></span>
        <div>
          <span><a href="<%= project.url %>"><%= project.name %></a></span>
          <% if (project.desc) { %>
            <p class="post-desc"><%- markdown(project.desc) %></p>
          <% } %>
        </div>
      </li>
    <% }); %>
  </ul>
</div>
